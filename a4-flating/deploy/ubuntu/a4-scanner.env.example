# Service bind
SCANNER_SERVICE_HOST=0.0.0.0
SCANNER_SERVICE_PORT=8008
SCANNER_SERVICE_TOKEN=change-me

# Camera selection (Ubuntu first camera is usually 0)
SCAN_CAMERA_INDEX=0
SCAN_CAMERA_BACKEND=V4L2
SCAN_CAMERA_FOURCC=MJPG

# Optional upload integration
# SCAN_UPLOAD_URL=https://your-api.example/upload
# SCAN_UPLOAD_TOKEN=YOUR_TOKEN

# Optional capture reset / unreadable notify integration
# SCAN_CAPTURE_RESET_URL=https://your-api.example/scan/reset
# SCAN_CAPTURE_RESET_TOKEN=YOUR_TOKEN
# SCAN_UNREADABLE_NOTIFY_URL=https://your-api.example/scan/unreadable
# SCAN_UNREADABLE_NOTIFY_TOKEN=YOUR_TOKEN

# Optional fisheye calibration file
# SCAN_FISHEYE_CALIBRATION_FILE=/opt/a4-flating/calibration/fisheye_test.npz
