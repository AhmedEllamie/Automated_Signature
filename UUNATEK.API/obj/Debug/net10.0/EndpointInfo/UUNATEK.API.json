{
  "openapi": "3.1.1",
  "info": {
    "title": "UUNATEK.API | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7086"
    },
    {
      "url": "http://localhost:5100"
    }
  ],
  "paths": {
    "/printer/connect": {
      "post": {
        "tags": [
          "Printer"
        ],
        "parameters": [
          {
            "name": "comPort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "baudRate",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/printer/disconnect": {
      "post": {
        "tags": [
          "Printer"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/printer/status": {
      "get": {
        "tags": [
          "Printer"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PrinterStatus"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrinterStatus"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrinterStatus"
                }
              }
            }
          }
        }
      }
    },
    "/printer/generate": {
      "post": {
        "tags": [
          "Printer"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "allOf": [
                  {
                    "type": "object",
                    "properties": {
                      "svg": {
                        "$ref": "#/components/schemas/IFormFile"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "Paper": {
                        "$ref": "#/components/schemas/Paper"
                      },
                      "Width": {
                        "type": "string"
                      },
                      "Height": {
                        "type": "string"
                      },
                      "XPosition": {
                        "type": "string"
                      },
                      "YPosition": {
                        "type": "string"
                      },
                      "Scale": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                          "integer",
                          "string"
                        ],
                        "format": "int32"
                      },
                      "Rotation": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                          "integer",
                          "string"
                        ],
                        "format": "int32"
                      },
                      "InvertX": {
                        "type": "boolean"
                      },
                      "InvertY": {
                        "type": "boolean"
                      }
                    }
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/printer/print": {
      "post": {
        "tags": [
          "Printer"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "allOf": [
                  {
                    "type": "object",
                    "properties": {
                      "svg": {
                        "$ref": "#/components/schemas/IFormFile"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "Paper": {
                        "$ref": "#/components/schemas/Paper"
                      },
                      "Width": {
                        "type": "string"
                      },
                      "Height": {
                        "type": "string"
                      },
                      "XPosition": {
                        "type": "string"
                      },
                      "YPosition": {
                        "type": "string"
                      },
                      "Scale": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                          "integer",
                          "string"
                        ],
                        "format": "int32"
                      },
                      "Rotation": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                          "integer",
                          "string"
                        ],
                        "format": "int32"
                      },
                      "InvertX": {
                        "type": "boolean"
                      },
                      "InvertY": {
                        "type": "boolean"
                      }
                    }
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PrintResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrintResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrintResponse"
                }
              }
            }
          }
        }
      }
    },
    "/printer/print/bulk": {
      "post": {
        "tags": [
          "Printer"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "allOf": [
                  {
                    "type": "object",
                    "properties": {
                      "svg": {
                        "$ref": "#/components/schemas/IFormFile"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "copies": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                          "integer",
                          "string"
                        ],
                        "format": "int32"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "Paper": {
                        "$ref": "#/components/schemas/Paper"
                      },
                      "Width": {
                        "type": "string"
                      },
                      "Height": {
                        "type": "string"
                      },
                      "XPosition": {
                        "type": "string"
                      },
                      "YPosition": {
                        "type": "string"
                      },
                      "Scale": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                          "integer",
                          "string"
                        ],
                        "format": "int32"
                      },
                      "Rotation": {
                        "pattern": "^-?(?:0|[1-9]\\d*)$",
                        "type": [
                          "integer",
                          "string"
                        ],
                        "format": "int32"
                      },
                      "InvertX": {
                        "type": "boolean"
                      },
                      "InvertY": {
                        "type": "boolean"
                      }
                    }
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PrintResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrintResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrintResponse"
                }
              }
            }
          }
        }
      }
    },
    "/printer/print-with-approval": {
      "post": {
        "tags": [
          "Printer"
        ],
        "parameters": [
          {
            "name": "paperImageBase64",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "allOf": [
                  {
                    "type": "object",
                    "properties": {
                      "paperImage": {
                        "$ref": "#/components/schemas/IFormFile"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "signatureSvg": {
                        "$ref": "#/components/schemas/IFormFile"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "printRequestJson": {
                        "type": "string"
                      }
                    }
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PrintWithApprovalResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrintWithApprovalResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrintWithApprovalResponse"
                }
              }
            }
          }
        }
      }
    },
    "/printer/requests/{requestId}": {
      "get": {
        "tags": [
          "Printer"
        ],
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/RequestLog"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestLog"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestLog"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IFormFile": {
        "type": "string",
        "format": "binary"
      },
      "Paper": {
        "type": "integer"
      },
      "PrinterStatus": {
        "type": "object",
        "properties": {
          "isOpen": {
            "type": "boolean"
          },
          "portName": {
            "type": "string"
          },
          "isPrinting": {
            "type": "boolean"
          }
        }
      },
      "PrintResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "commandsSent": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "copies": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "totalCommandsSent": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "PrintWithApprovalResponse": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string"
          },
          "wasApproved": {
            "type": "boolean"
          },
          "wasPrinted": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "commandsSent": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "RequestLog": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "requestId": {
            "type": "string",
            "format": "uuid"
          },
          "paperImagePath": {
            "type": [
              "null",
              "string"
            ]
          },
          "signatureSvgPath": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/RequestStatus"
          },
          "approvalResponse": {
            "type": [
              "null",
              "string"
            ]
          },
          "errorMessage": {
            "type": [
              "null",
              "string"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "completedAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "RequestStatus": {
        "type": "integer"
      }
    }
  },
  "tags": [
    {
      "name": "Printer"
    }
  ]
}