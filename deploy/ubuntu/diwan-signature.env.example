# Copy this file to /etc/diwan-signature/diwan-signature.env and edit values.
#
# Required inbound API authentication for Flask (/api/*) and FastAPI (/printer/*):
PLOTTER_API_KEY=QSCWDVEFBRGNTHM
#
# Required for capture request flow:
CAPTURE_RESET_URL=http://127.0.0.1:9000/reset
#
# Optional capture settings:
CAPTURE_RESET_TOKEN=
CAPTURE_RESET_TIMEOUT_SECONDS=8.0
CAPTURE_RESET_METHOD=POST
#
# Optional scanner service settings (if scanner integration is enabled):
SCANNER_SERVICE_BASE_URL=http://127.0.0.1:8008
